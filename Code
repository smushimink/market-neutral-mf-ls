def construct_portfolio(signal: pd.DataFrame,
                        universe: pd.DataFrame,
                        config: dict,
                        date: pd.Timestamp) -> pd.Series:
    """
    Build target portfolio weights for a given signal date (Monday close).

    Steps:
    1. Rank stocks by composite signal
    2. Long top quantile, short bottom quantile
    3. Equal-weight within sides, cap per-name at 2%
    4. Enforce min names (60 long, 15 short)
    5. Scale to 120% long / 30% short
    """
    sig = signal.loc[date].dropna()
    univ = universe.loc[date]
    sig = sig[univ[univ].index.intersection(sig.index)]

    n = len(sig)

    # Dynamically adjust minimums if universe is too small for configured caps
    min_l = min(config['min_longs'], n // 2)
    min_s = min(config['min_shorts'], n // 4)

    if n < min_l + min_s:
        return pd.Series(dtype=float)

    # Quantile cutoffs
    long_cut = sig.quantile(1 - config['long_quantile'])
    short_cut = sig.quantile(config['short_quantile'])

    longs = sig[sig >= long_cut].index
    shorts = sig[sig <= short_cut].index
    shorts = shorts.difference(longs)  # Remove overlap

    # Enforce minimums — if not enough, expand quantile
    if len(longs) < min_l:
        longs = sig.nlargest(min_l).index
    if len(shorts) < min_s:
        shorts = sig.nsmallest(min_s).index
        shorts = shorts.difference(longs)

    if len(longs) < min_l or len(shorts) < max(min_s, 1):
        return pd.Series(dtype=float)

    # Equal weight within sides
    w_long = config['long_exposure'] / len(longs)
    w_short = -config['short_exposure'] / len(shorts)

    weights = pd.Series(0.0, index=sig.index)
    weights[longs] = w_long
    weights[shorts] = w_short

    # Cap per-name
    cap = config['max_weight_per_name']
    weights = weights.clip(-cap, cap)

    # Re-scale to target exposures
    long_total = weights[weights > 0].sum()
    short_total = weights[weights < 0].sum()
    if long_total > 0:
        weights.loc[weights > 0] *= config['long_exposure'] / long_total
    if short_total < 0:
        weights.loc[weights < 0] *= config['short_exposure'] / abs(short_total)

    # Final clip
    weights = weights.clip(-cap, cap)

    return weights[weights != 0]


