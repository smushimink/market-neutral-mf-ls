# 10. RIDGE REGRESSION (WALK-FORWARD)
# ============================================================================

def ridge_walkforward(F, data, univ, cfg):
    """Walk-forward Ridge predicting 5-day forward return (open-to-open)."""
    print("\n[MODEL] Walk-forward Ridge regression...")

    op = data['open']
    fwd = op.pct_change(5).shift(-5)
    fnames = list(F.keys())
    idx = data['adj_close'].index
    preds = pd.DataFrame(np.nan, index=idx, columns=data['adj_close'].columns)

    bt_start = pd.Timestamp(cfg['start'])
    bt_end = pd.Timestamp(cfg['end'])
    tw = cfg['train_window']
    step = cfg['wf_step']
    steps = pd.date_range(bt_start, bt_end, freq=f'{step}B')
    n_ok = 0

    for ts in steps:
        te = ts - pd.Timedelta(days=1)
        tr_dates = idx[idx <= te][-tw:]
        test_dates = idx[(idx >= ts) & (idx < ts + pd.Timedelta(days=step*2))]

        if len(tr_dates) < tw // 2:
            continue

        # Training data (sample every 5th day)
        Xp = []
        for fn in fnames:
            Xp.append(F[fn].loc[tr_dates[::5]].stack().rename(fn))
        X = pd.concat(Xp, axis=1).dropna()
        y = fwd.loc[tr_dates[::5]].stack().rename('y')
        c = X.index.intersection(y.dropna().index)
        if len(c) < 200:
            continue

        X_tr, y_tr = X.loc[c], y.loc[c]
        sc = StandardScaler()
        Xs = sc.fit_transform(X_tr)
        mdl = Ridge(alpha=1.0).fit(Xs, y_tr)

        for d in test_dates:
            if d not in idx:
                continue
            xp = []
            for fn in fnames:
                if d in F[fn].index:
                    xp.append(F[fn].loc[d].rename(fn))
            if len(xp) == len(fnames):
                xt = pd.concat(xp, axis=1).dropna()
                if len(xt) > 0:
                    preds.loc[d, xt.index] = mdl.predict(sc.transform(xt))
        n_ok += 1

    preds = zscore_xs(preds)
    valid = preds.notna().sum(axis=1)
    vd = valid[valid > 0]
    print(f"[MODEL] {n_ok} steps, {len(vd)} days, avg {vd.mean():.0f} stocks/day")
    return preds


