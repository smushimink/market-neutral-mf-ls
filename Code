def get_sp500_tickers() -> List[str]:
    """
    Get current S&P 500 constituents from Wikipedia.
    SURVIVORSHIP BIAS: current members only.
    Bias direction: UPWARD (+1–3% annualized) because delisted/dropped
    stocks (typically underperformers) are never held.
    """
    try:
        # Try with lxml first, fall back to html.parser
        try:
            table = pd.read_html(
                'https://en.wikipedia.org/wiki/List_of_S%26P_500_companies',
                flavor='lxml'
            )
        except Exception:
            table = pd.read_html(
                'https://en.wikipedia.org/wiki/List_of_S%26P_500_companies',
                flavor='html.parser'
            )
        tickers = table[0]['Symbol'].tolist()
        tickers = [t.replace('.', '-') for t in tickers]
        # Also grab sector info for sector constraints
        sectors = dict(zip(
            [t.replace('.', '-') for t in table[0]['Symbol']],
            table[0]['GICS Sector']
        ))
        print(f"[DATA] Retrieved {len(tickers)} S&P 500 tickers")
        return tickers, sectors
    except Exception as e:
        print(f"[DATA] Wikipedia scrape failed: {e}. Using fallback.")
        return _fallback_tickers(), {}


