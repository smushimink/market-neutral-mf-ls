def download_data(tickers: List[str], config: dict) -> Dict[str, pd.DataFrame]:
    """
    Download OHLCV from yfinance.
    Returns dict: 'adj_close', 'open', 'close', 'volume'
    Indexed by date, columns = tickers.
    """
    cache = config['cache_path']
    if os.path.exists(cache):
        print(f"[DATA] Loading cache: {cache}")
        with open(cache, 'rb') as f:
            data = pickle.load(f)
        print(f"[DATA] {len(data['adj_close'].columns)} tickers, "
              f"{len(data['adj_close'])} days")
        return data

    try:
        import yfinance as yf
    except ImportError:
        raise ImportError("pip install yfinance")

    warmup_start = (
        pd.Timestamp(config['start_date'])
        - pd.Timedelta(days=config['warmup_days'] * 2)
    ).strftime('%Y-%m-%d')

    print(f"[DATA] Downloading {len(tickers)} tickers ({warmup_start} to {config['end_date']})...")
    print("[DATA] First run takes 10-20 minutes.")

    raw = yf.download(
        tickers, start=warmup_start, end=config['end_date'],
        auto_adjust=False, threads=True, progress=True,
    )

    if raw.empty:
        raise ValueError("[DATA] Empty download. Check connection/tickers.")

    data = {}
    field_map = {
        'adj_close': 'Adj Close',
        'open': 'Open',
        'close': 'Close',
        'volume': 'Volume',
    }
    for key, col in field_map.items():
        if isinstance(raw.columns, pd.MultiIndex):
            data[key] = raw[col].copy()
        else:
            data[key] = raw[[col]].copy()
            data[key].columns = tickers[:1]

    # Drop tickers with insufficient data
    valid = data['adj_close'].notna().sum() >= config['min_history_days']
    keep = valid[valid].index.tolist()
    for k in data:
        data[k] = data[k][keep]
    print(f"[DATA] Kept {len(keep)} tickers with >= {config['min_history_days']} days")

    with open(cache, 'wb') as f:
        pickle.dump(data, f)
    return data


