        ('MDD < 20%', abs(m['mdd']) < 0.20, f"{m['mdd']:.1%}"),
        ('p < 0.05', m['p'] < 0.05, f"{m['p']:.4f}"),
        ('Hit > 50%', m['hit'] > 0.50, f"{m['hit']:.1%}"),
        ('Calmar > 0.5', m['calmar'] > 0.5, f"{m['calmar']:.2f}"),
    ]

    ps = 0
    for name, ok, val in checks:
        tag = "PASS" if ok else "FAIL"
        if ok: ps += 1
        print(f"  [{tag}] {name}: {val}")

    print(f"\n  Score: {ps}/{len(checks)}")
    if ps >= 5:
        print("  → CONDITIONAL GO: paper-trade with small allocation")
        print("    Caveats: survivorship bias, yfinance data quality, no point-in-time GICS")
    elif ps >= 3:
        print("  → INVESTIGATE: needs survivorship-free data + broader universe")
    else:
        print("  → NO-GO: insufficient evidence of alpha")
        print("    Possible causes: crowded factors, small universe, free-data limitations")


