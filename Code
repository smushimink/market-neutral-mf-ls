def make_universe(data: dict, cfg: dict) -> pd.DataFrame:
    """Daily boolean mask. Filters use only past data."""
    c = data['adj_close']
    v = data['volume']
    ok_price = c >= cfg['min_price']
    ok_adv = (c * v).rolling(20, min_periods=15).mean() >= cfg['min_adv_usd']
    ok_hist = c.expanding().count() >= cfg['min_history']
    u = ok_price & ok_adv & ok_hist
    avg = u.sum(axis=1).mean()
    print(f"[UNIVERSE] Avg size: {avg:.0f}/day")
    print(f"[UNIVERSE] ⚠ Survivorship bias: UPWARD. "
          f"Partially offset for mkt-neutral (est +0.5–1.5% ann).")
    return u


