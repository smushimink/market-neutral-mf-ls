def get_tickers() -> Tuple[List[str], Dict[str, str]]:
    """
    Get a broad set of US large-cap tickers.
    Try Wikipedia S&P 500 first; fall back to hardcoded ~200 names.

    SURVIVORSHIP BIAS:
    - Using current constituents only.
    - ~20-25 names rotate annually.
    - Bias direction: UPWARD. Dropped stocks are typically underperformers.
    - Estimated magnitude: +1 to +3% annualized return inflation.
    - For market-neutral: bias is partially offset (both sides affected),
      but bottom-quintile stocks are more likely to include future deletions,
      so short side is biased toward stocks that actually performed worse
      than shown → net bias is SMALLER than for long-only, maybe +0.5-1.5%.
    """
    sectors = {}
    try:
        try:
            tables = pd.read_html(
                'https://en.wikipedia.org/wiki/List_of_S%26P_500_companies',
                flavor='lxml')
        except Exception:
            tables = pd.read_html(
                'https://en.wikipedia.org/wiki/List_of_S%26P_500_companies',
                flavor='html.parser')
        df = tables[0]
        tickers = [t.replace('.', '-') for t in df['Symbol'].tolist()]
        sectors = dict(zip(
            [t.replace('.', '-') for t in df['Symbol']],
            df['GICS Sector']
        ))
