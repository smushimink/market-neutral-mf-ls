def metrics(r: pd.Series, label: str = "") -> Dict:
    """Full performance metrics from daily returns."""
    r = r.dropna()
    if len(r) < 20:
        return {'label': label, 'error': 'insufficient data'}

    ann_ret = r.mean() * 252
    ann_vol = r.std() * np.sqrt(252)
    sharpe = ann_ret / ann_vol if ann_vol > 0 else 0

    down = r[r < 0]
    down_std = down.std() * np.sqrt(252) if len(down) > 0 else ann_vol
    sortino = ann_ret / down_std if down_std > 0 else 0

    cum = (1 + r).cumprod()
    dd = (cum / cum.cummax()) - 1
    max_dd = dd.min()
    calmar = ann_ret / abs(max_dd) if max_dd != 0 else 0

    hit = (r > 0).mean()
    avg_w = r[r > 0].mean() if (r > 0).any() else 0
    avg_l = r[r < 0].mean() if (r < 0).any() else 0
    wl = abs(avg_w / avg_l) if avg_l != 0 else np.inf

    t, p = stats.ttest_1samp(r, 0)
    var5 = r.quantile(0.05)
    cvar5 = r[r <= var5].mean() if (r <= var5).any() else var5

    return {
        'label': label, 'days': len(r),
        'ann_return': ann_ret, 'ann_vol': ann_vol,
        'sharpe': sharpe, 'sortino': sortino,
        'max_dd': max_dd, 'calmar': calmar,
        'hit_rate': hit, 'avg_win': avg_w, 'avg_loss': avg_l,
        'win_loss': wl, 'skew': r.skew(), 'kurt': r.kurtosis(),
        't_stat': t, 'p_value': p,
        'var_5': var5, 'cvar_5': cvar5,
    }


def rolling_sharpe(r: pd.Series, window: int = 252) -> pd.Series:
    mu = r.rolling(window, min_periods=window // 2).mean() * 252
    sd = r.rolling(window, min_periods=window // 2).std() * np.sqrt(252)
    return mu / sd.replace(0, np.nan)


def rolling_beta(strat: pd.Series, bench: pd.Series, window: int = 63) -> pd.Series:
    """Rolling beta vs benchmark."""
    df = pd.concat([strat, bench], axis=1).dropna()
    df.columns = ['s', 'b']
    cov = df['s'].rolling(window).cov(df['b'])
    var = df['b'].rolling(window).var()
    return (cov / var.replace(0, np.nan)).rename('beta')


def bootstrap_sharpe(r: pd.Series, n: int = 1000) -> Tuple[float, float]:
    """95% CI on Sharpe via bootstrap."""
    vals = r.dropna().values
    sharpes = []
    for _ in range(n):
        s = np.random.choice(vals, size=len(vals), replace=True)
        sd = s.std()
        sharpes.append(s.mean() / sd * np.sqrt(252) if sd > 0 else 0)
    return np.percentile(sharpes, 2.5), np.percentile(sharpes, 97.5)


