def perf(r: pd.Series, label: str = "") -> dict:
    r = r.dropna()
    if len(r) < 20:
        return {'label': label, 'err': True}
    ar = r.mean() * 252
    av = r.std() * np.sqrt(252)
    sr = ar / av if av > 0 else 0
    dn = r[r < 0]
    dsd = dn.std() * np.sqrt(252) if len(dn) > 0 else av
    so = ar / dsd if dsd > 0 else 0
    cum = (1 + r).cumprod()
    dd = cum / cum.cummax() - 1
    mdd = dd.min()
    cal = ar / abs(mdd) if mdd != 0 else 0
    hr = (r > 0).mean()
    aw = r[r > 0].mean() if (r > 0).any() else 0
    al = r[r < 0].mean() if (r < 0).any() else 0
    wl = abs(aw / al) if al != 0 else np.inf
    t, p = stats.ttest_1samp(r, 0)
    v5 = r.quantile(0.05)
    cv5 = r[r <= v5].mean() if (r <= v5).any() else v5
    return {
        'label': label, 'n': len(r),
        'ret': ar, 'vol': av, 'sharpe': sr, 'sortino': so,
        'mdd': mdd, 'calmar': cal, 'hit': hr,
        'avg_w': aw, 'avg_l': al, 'wl': wl,
        'skew': r.skew(), 'kurt': r.kurtosis(),
        't': t, 'p': p, 'var5': v5, 'cvar5': cv5,
    }


def rolling_sharpe(r, win=252):
    mu = r.rolling(win, min_periods=win//2).mean() * 252
    sd = r.rolling(win, min_periods=win//2).std() * np.sqrt(252)
    return mu / sd.replace(0, np.nan)


def rolling_beta(s, b, win=63):
    df = pd.concat([s, b], axis=1).dropna()
    df.columns = ['s', 'b']
    cov = df['s'].rolling(win).cov(df['b'])
    var = df['b'].rolling(win).var()
    return (cov / var.replace(0, np.nan)).rename('beta')


def bootstrap_ci(r, n=1000):
    v = r.dropna().values
    srs = []
    for _ in range(n):
        s = np.random.choice(v, len(v), replace=True)
        sd = s.std()
        srs.append(s.mean() / sd * np.sqrt(252) if sd > 0 else 0)
    return np.percentile(srs, 2.5), np.percentile(srs, 97.5)


