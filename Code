    checks = [
        ('Net Sharpe > 0.3', m['sharpe'] > 0.3, f"{m['sharpe']:.2f}"),
        ('Net Sharpe < 1.5 (not suspicious)', m['sharpe'] < 1.5, f"{m['sharpe']:.2f}"),
        ('Max DD < 25%', abs(m['max_dd']) < 0.25, f"{m['max_dd']:.1%}"),
