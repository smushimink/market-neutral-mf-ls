def test_placebo(F, univ, data, cfg, n=3):
    print(f"\n[ROBUST] Placebo ({n} shuffles)...")
    res = []
    for i in range(n):
        comp = composite_signal(F, cfg)
        shuf = comp.copy()
        for d in shuf.index[::5]:  # Sample for speed
            v = shuf.loc[d].dropna()
            if len(v) > 0:
                sv = v.values.copy()
                np.random.shuffle(sv)
                shuf.loc[d, v.index] = sv
        bt = backtest(shuf, univ, data, cfg, label=f"Placebo{i+1}")
        m = perf(bt['ret_n'])
        s = m.get('sharpe', 0)
        res.append(s)
        print(f"  Placebo {i+1}: SR = {s:.3f}")
    return res


def test_shifted(F, univ, data, cfg):
    print("\n[ROBUST] Shifted signal (t+1 features — should show look-ahead inflation)...")
    shifted = {k: v.shift(-1) for k, v in F.items()}
    sig = composite_signal(shifted, cfg)
    bt = backtest(sig, univ, data, cfg, label="Shifted_t+1")
    m = perf(bt['ret_n'])
    s = m.get('sharpe', 0)
    print(f"  Shifted SR: {s:.3f}")
    return s


def test_ablation(F, univ, data, cfg):
    print("\n[ROBUST] Factor ablation (each solo)...")
    res = {}
    for k in F:
        bt = backtest(F[k], univ, data, cfg, label=f"Solo_{k}")
        m = perf(bt['ret_n'])
        s = m.get('sharpe', 0)
        res[k] = s
        print(f"  {k}: SR = {s:.3f}")
    return res


def test_cost_stress(sig, univ, data, cfg):
    print("\n[ROBUST] Cost stress test...")
    res = {}
    for bps in cfg['cost_stress']:
        bt = backtest(sig, univ, data, cfg, cost_bps=bps, label=f"Cost_{bps:.0f}bp")
        m = perf(bt['ret_n'])
        s = m.get('sharpe', 0)
        res[bps] = s
        print(f"  {bps:.0f} bps: Net SR = {s:.3f}")
    return res


def test_weight_perturb(F, univ, data, cfg):
    """Perturb factor weights ±20% and report Sharpe stability."""
    print("\n[ROBUST] Weight perturbation ±20%...")
    base_w = cfg['factor_weights'].copy()
    results = {}

    for factor in base_w:
        for delta in [-0.20, +0.20]:
            test_w = base_w.copy()
            # Adjust this factor and renormalize
            test_w[factor] = max(0.05, base_w[factor] * (1 + delta))
            total = sum(test_w.values())
            test_w = {k: v / total for k, v in test_w.items()}

            test_cfg = cfg.copy()
            test_cfg['factor_weights'] = test_w
            sig = composite_signal(F, test_cfg)
            bt = backtest(sig, univ, data, cfg, label=f"{factor}_{delta:+.0%}")
            m = perf(bt['ret_n'])
            key = f"{factor} {delta:+.0%}"
            results[key] = m.get('sharpe', 0)
            print(f"  {key}: SR = {m.get('sharpe', 0):.3f}")

    return results


