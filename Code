def save_charts(results, spy_ret, outdir):
    os.makedirs(outdir, exist_ok=True)
    fig, axes = plt.subplots(2, 2, figsize=(16, 12))
    fig.suptitle('Market-Neutral Multi-Factor — Dashboard', fontsize=14, fontweight='bold')

    # Cumulative
    ax = axes[0, 0]
    for r in results:
        c = (1 + r['ret_n']).cumprod()
        ax.plot(c.index, c.values, label=r['label'] + ' (Net)')
    if spy_ret is not None:
        sc = (1 + spy_ret).cumprod()
        ax.plot(sc.index, sc.values, label='SPY', color='gray', ls='--', alpha=.6)
    ax.set_title('Cumulative Returns')
    ax.legend(fontsize=8); ax.grid(alpha=.3); ax.set_ylabel('$1 Growth')

    # Drawdown
    ax = axes[0, 1]
    for r in results:
        c = (1 + r['ret_n']).cumprod()
        dd = c / c.cummax() - 1
        ax.fill_between(dd.index, dd.values, 0, alpha=.3, label=r['label'])
    ax.set_title('Drawdown'); ax.legend(fontsize=8); ax.grid(alpha=.3)

    # Rolling Sharpe
    ax = axes[1, 0]
    for r in results:
        rs = rolling_sharpe(r['ret_n'])
        ax.plot(rs.index, rs.values, label=r['label'])
    ax.axhline(0, color='red', ls='--', alpha=.5)
    ax.set_title('Rolling 12M Sharpe'); ax.legend(fontsize=8); ax.grid(alpha=.3)

    # Rolling beta
    ax = axes[1, 1]
    if spy_ret is not None:
        for r in results:
            b = rolling_beta(r['ret_n'], spy_ret)
            ax.plot(b.index, b.values, label=r['label'])
        ax.axhline(CFG['target_beta_lo'], color='red', ls=':', alpha=.5)
        ax.axhline(CFG['target_beta_hi'], color='red', ls=':', alpha=.5)
        ax.axhline(0, color='black', ls='-', alpha=.3)
        ax.set_title('Rolling 63d Beta vs SPY')
        ax.legend(fontsize=8); ax.grid(alpha=.3)

    plt.tight_layout()
    p = os.path.join(outdir, 'dashboard.png')
    plt.savefig(p, dpi=150, bbox_inches='tight')
    plt.close()
    print(f"\n[CHART] Saved: {p}")
    return p


