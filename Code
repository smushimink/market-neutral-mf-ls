# 4. FEATURES
# ============================================================================

def winsorize_xs(df, pct=0.01):
    lo = df.quantile(pct, axis=1)
    hi = df.quantile(1 - pct, axis=1)
    return df.clip(lower=lo, upper=hi, axis=0)

def zscore_xs(df):
    mu = df.mean(axis=1)
    sd = df.std(axis=1).replace(0, np.nan)
    return df.sub(mu, axis=0).div(sd, axis=0)


def build_features(data: dict, univ: pd.DataFrame, cfg: dict) -> Dict[str, pd.DataFrame]:
    """All features use data at Monday close. No look-ahead."""
    c = data['adj_close']
    vol = data['volume']
    F = {}

    # A: Reversal (contrarian 5d return)
    r5 = c.pct_change(cfg['rev_lookback'])
    ts_mu = r5.rolling(cfg['rev_zscore_win'], min_periods=30).mean()
    ts_sd = r5.rolling(cfg['rev_zscore_win'], min_periods=30).std().replace(0, np.nan)
    F['reversal'] = zscore_xs(winsorize_xs(-(r5 - ts_mu) / ts_sd, cfg['winsorize']))

    # B: Momentum 12-1
    r12 = c.pct_change(cfg['mom_long'])
    r1 = c.pct_change(cfg['mom_short'])
    F['mom_12_1'] = zscore_xs(winsorize_xs(r12 - r1, cfg['winsorize']))

    # C: Low-vol
    rv = c.pct_change(1).rolling(cfg['vol_lookback'], min_periods=15).std()
    F['low_vol'] = zscore_xs(winsorize_xs(-rv, cfg['winsorize']))

    # D: Volume shock interaction
    va = vol.rolling(cfg['vol_avg_lookback'], min_periods=15).mean().replace(0, np.nan)
    vr = vol / va
    vz = zscore_xs(winsorize_xs(vr, cfg['winsorize']))
    r1d = c.pct_change(1)
    F['vol_shock'] = zscore_xs(winsorize_xs(vz * np.sign(-r1d), cfg['winsorize']))

    for k in F:
        F[k] = F[k].where(univ)

    print(f"[FEATURES] {len(F)} factors:")
    for k, v in F.items():
        print(f"  {k}: {v.notna().sum(axis=1).mean():.0f} stocks/day")
    return F


def composite_signal(F: dict, cfg: dict) -> pd.DataFrame:
    """Equal-weight composite → cross-sectional z-score."""
    w = cfg['factor_weights']
    sig = sum(w[k] * F[k].fillna(0) for k in w)
    sig = zscore_xs(sig)
    print(f"[SIGNAL] Composite: {sig.notna().sum(axis=1).mean():.0f} stocks/day")
    return sig


def factor_corr(F: dict) -> pd.DataFrame:
    """Average cross-sectional factor correlations (sampled)."""
    names = list(F.keys())
    dates = F[names[0]].dropna(how='all').index
    sample = np.random.choice(dates, min(200, len(dates)), replace=False)
    corrs = []
    for d in sample:
        vals = pd.DataFrame({k: F[k].loc[d] for k in names}).dropna()
        if len(vals) > 20:
            corrs.append(vals.corr())
    if corrs:
        avg = sum(corrs) / len(corrs)
    else:
        avg = pd.DataFrame(np.eye(len(names)), index=names, columns=names)
    print("\n[FEATURES] Avg factor correlation:")
    print(avg.round(3).to_string())
    return avg


# ============================================================================
# 5. PORTFOLIO CONSTRUCTION — MARKET NEUTRAL
# ============================================================================

def build_portfolio(sig: pd.DataFrame, univ: pd.DataFrame,
                    cfg: dict, date: pd.Timestamp,
                    sector_map: dict = None) -> pd.Series:
    """
    Market-neutral portfolio: 75% long / 75% short, net ≈ 0%.
    Equal-weight within sides, capped at 1.5% per name.
    """
    s = sig.loc[date].dropna()
    u = univ.loc[date]
    s = s[u[u].index.intersection(s.index)]
    n = len(s)

    # Dynamic minimums based on available universe
    min_side = min(cfg['min_per_side'], n // 3)
    if n < min_side * 2:
        return pd.Series(dtype=float)

    lc = s.quantile(1 - cfg['long_quantile'])
    sc = s.quantile(cfg['short_quantile'])

    longs = s[s >= lc].index
    shorts = s[s <= sc].index
    shorts = shorts.difference(longs)

    if len(longs) < min_side:
        longs = s.nlargest(min_side).index
    if len(shorts) < min_side:
        shorts = s.nsmallest(min_side).index
        shorts = shorts.difference(longs)

    if len(longs) < max(min_side, 1) or len(shorts) < max(min_side, 1):
        return pd.Series(dtype=float)

    # Equal-weight, capped
    wl = cfg['long_exposure'] / len(longs)
    ws = -cfg['short_exposure'] / len(shorts)
    cap = cfg['max_weight']

    weights = pd.Series(0.0, index=s.index)
    weights[longs] = min(wl, cap)
    weights[shorts] = max(ws, -cap)

    # Re-scale to target exposures
    lt = weights[weights > 0].sum()
    st = weights[weights < 0].sum()
    if lt > 0:
        weights.loc[weights > 0] *= cfg['long_exposure'] / lt
    if st < 0:
        weights.loc[weights < 0] *= cfg['short_exposure'] / abs(st)

    # Final clip
    weights = weights.clip(-cap, cap)

    # Check net exposure
    net = weights.sum()
    gross = weights.abs().sum()
    # If net exposure drifts, adjust proportionally
    if abs(net) > 0.05 * gross and gross > 0:
        # Reduce the larger side slightly
        if net > 0:
            weights.loc[weights > 0] *= (cfg['long_exposure'] - net/2) / weights[weights > 0].sum()
        else:
            adjustment = abs(net) / 2
            weights.loc[weights < 0] *= (cfg['short_exposure'] - adjustment) / abs(weights[weights < 0].sum())

    return weights[weights != 0]


