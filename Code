# 7. BACKTESTER
# ============================================================================

def backtest(sig: pd.DataFrame, univ: pd.DataFrame, data: dict,
             cfg: dict, cost_bps: float = None, label: str = "Strat",
             sector_map: dict = None) -> dict:
    """
    Weekly rebalance backtest with proper execution timing.
    Signal Monday close → trade Tuesday open → hold to next Tuesday open.
    """
    if cost_bps is None:
        cost_bps = cfg['cost_one_way_bps']

    ac = data['adj_close']
    op = data['open']
    idx = ac.index

    rdates = rebalance_dates(idx, cfg['start'], cfg['end'])
    if len(rdates) < 10:
        raise ValueError(f"Only {len(rdates)} rebalance dates")

    # Map signal dates to execution dates (next trading day)
    exec_dates = []
    for rd in rdates:
        nxt = idx[idx > rd]
        exec_dates.append(pd.Timestamp(nxt[0]) if len(nxt) > 0 else None)

    print(f"[BT:{label}] {len(rdates)} rebalances "
          f"({rdates[0].date()} → {rdates[-1].date()}), cost={cost_bps}bps")

    rets, dates_out, to_list = [], [], []
    prev_w = pd.Series(dtype=float)

    for i in range(len(rdates) - 1):
        sd = rdates[i]          # Signal date (Mon close)
        ed = exec_dates[i]      # Entry (Tue open)
        xd = exec_dates[i + 1]  # Exit (next Tue open)

        if ed is None or xd is None:
            continue

        # Find nearest valid signal date
        valid_sig = sig.index[sig.index <= sd]
        if len(valid_sig) == 0:
            continue
        sd_actual = valid_sig[-1]

        w = build_portfolio(sig, univ, cfg, sd_actual, sector_map)
        if len(w) == 0:
            continue

        # Turnover
        ci = w.index.union(prev_w.index)
        tw = w.reindex(ci, fill_value=0)
        pw = prev_w.reindex(ci, fill_value=0)
        to = (tw - pw).abs().sum() / 2
        to_list.append({'date': sd, 'turnover': to})

        # Holding period daily returns
        hold = idx[(idx >= ed) & (idx < xd)]
        for j, hd in enumerate(hold):
            if j == 0:
                # Entry day: open → close
                o = op.loc[hd].reindex(w.index)
                c = ac.loc[hd].reindex(w.index)
                ok = o.notna() & c.notna() & (o > 0)
                if ok.any():
                    dr = (c[ok] / o[ok]) - 1
                    pr = (w.reindex(dr.index, fill_value=0) * dr).sum()
                    rets.append(pr)
                    dates_out.append(hd)
            else:
                p0 = ac.loc[hold[j-1]].reindex(w.index)
                p1 = ac.loc[hd].reindex(w.index)
                ok = p0.notna() & p1.notna() & (p0 > 0)
                if ok.any():
                    dr = (p1[ok] / p0[ok]) - 1
                    pr = (w.reindex(dr.index, fill_value=0) * dr).sum()
                    rets.append(pr)
                    dates_out.append(hd)

        prev_w = w.copy()

    ret_g = pd.Series(rets, index=pd.DatetimeIndex(dates_out), name=label)

    # Costs
    to_df = pd.DataFrame(to_list)
    avg_to = to_df['turnover'].mean() if len(to_df) > 0 else 0
    ann_to = avg_to * 52

    daily_cost = avg_to * (cost_bps * 2) / 10000 / 5  # RT cost spread over 5d
    daily_borrow = cfg['borrow_annual_bps'] / 10000 / 252 * cfg['short_exposure']

    ret_n = ret_g - daily_cost - daily_borrow

    return {
        'ret_g': ret_g, 'ret_n': ret_n,
        'avg_to': avg_to, 'ann_to': ann_to,
        'cost_bps': cost_bps, 'label': label,
    }


