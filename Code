def winsorize_xs(df: pd.DataFrame, pct: float = 0.01) -> pd.DataFrame:
    """Winsorize each cross-section (row) at pct and 1-pct."""
    lo = df.quantile(pct, axis=1)
    hi = df.quantile(1 - pct, axis=1)
    return df.clip(lower=lo, upper=hi, axis=0)


def zscore_xs(df: pd.DataFrame) -> pd.DataFrame:
    """Cross-sectional z-score (each row independently)."""
    mu = df.mean(axis=1)
    sigma = df.std(axis=1).replace(0, np.nan)
    return df.sub(mu, axis=0).div(sigma, axis=0)


def compute_features(data: Dict[str, pd.DataFrame],
                     universe: pd.DataFrame,
                     config: dict) -> Dict[str, pd.DataFrame]:
    """
    Compute all alpha factors using data available at Monday close.
    All features are cross-sectionally z-scored after winsorization.
    """
    close = data['adj_close']
    volume = data['volume']
    features = {}

    # ---- Factor A: Short-Term Reversal (contrarian) ----
    # 5-day return, then time-series z-score (63d), then cross-sectional z-score
    ret_5d = close.pct_change(config['reversal_lookback'])
    ts_mu = ret_5d.rolling(config['reversal_zscore_window'], min_periods=30).mean()
    ts_sd = ret_5d.rolling(config['reversal_zscore_window'], min_periods=30).std().replace(0, np.nan)
    ts_z = (ret_5d - ts_mu) / ts_sd
    # Contrarian: flip sign (negative return → buy)
    rev_raw = -ts_z
    features['reversal'] = zscore_xs(winsorize_xs(rev_raw, config['winsorize_pct']))

    # ---- Factor B: Momentum 12-1 ----
    ret_12m = close.pct_change(config['momentum_long_lookback'])
    ret_1m = close.pct_change(config['momentum_short_lookback'])
    mom_raw = ret_12m - ret_1m
    features['momentum_12_1'] = zscore_xs(winsorize_xs(mom_raw, config['winsorize_pct']))

    # ---- Factor C: Low Volatility ----
    daily_ret = close.pct_change(1)
    rvol = daily_ret.rolling(config['volatility_lookback'], min_periods=15).std()
    lowvol_raw = -rvol  # Lower vol → higher score
    features['low_vol'] = zscore_xs(winsorize_xs(lowvol_raw, config['winsorize_pct']))

    # ---- Factor D: Volume Surprise Interaction ----
    vol_avg = volume.rolling(config['volume_avg_lookback'], min_periods=15).mean().replace(0, np.nan)
    vol_ratio = volume / vol_avg
    vol_z = zscore_xs(winsorize_xs(vol_ratio, config['winsorize_pct']))
    ret_1d = close.pct_change(1)
    interaction = vol_z * np.sign(-ret_1d)  # High vol + down day → positive → buy
    features['vol_surprise'] = zscore_xs(winsorize_xs(interaction, config['winsorize_pct']))

    # ---- Apply universe mask ----
    for k in features:
        features[k] = features[k].where(universe)

    # ---- Report coverage ----
    print(f"[FEATURES] {len(features)} factors computed:")
    for name, df in features.items():
        cov = df.notna().sum(axis=1).mean()
        print(f"  {name}: avg {cov:.0f} stocks/day")

    return features


def compute_composite(features: Dict[str, pd.DataFrame],
                      config: dict) -> pd.DataFrame:
    """Weighted composite of z-scored factors → re-z-scored."""
    w = config['factor_weights']
    composite = sum(w[k] * features[k].fillna(0) for k in w)
    composite = zscore_xs(composite)
    print(f"[SIGNAL] Composite: avg {composite.notna().sum(axis=1).mean():.0f} stocks/day")
    return composite


def factor_correlation_matrix(features: Dict[str, pd.DataFrame]) -> pd.DataFrame:
    """Average cross-sectional correlation between factors."""
    names = list(features.keys())
    n = len(names)
    corr_matrix = pd.DataFrame(np.eye(n), index=names, columns=names)

    # Sample 100 random dates for speed
    common_dates = features[names[0]].dropna(how='all').index
    sample_dates = np.random.choice(common_dates, size=min(100, len(common_dates)), replace=False)

    corrs = {(a, b): [] for a in names for b in names}
    for d in sample_dates:
        vals = pd.DataFrame({k: features[k].loc[d] for k in names}).dropna()
        if len(vals) > 10:
            c = vals.corr()
            for a in names:
                for b in names:
                    corrs[(a, b)].append(c.loc[a, b])

    for a in names:
        for b in names:
            if corrs[(a, b)]:
                corr_matrix.loc[a, b] = np.mean(corrs[(a, b)])

    print("\n[FEATURES] Average cross-sectional factor correlation:")
    print(corr_matrix.round(3).to_string())
    return corr_matrix


