def find_rebalance_dates(index: pd.DatetimeIndex,
                         start: str, end: str) -> List[pd.Timestamp]:
    """
    Find Monday signal dates within the backtest window.
    If Monday is missing (holiday), use the first trading day of that week.
    Returns list of pd.Timestamp (not numpy.datetime64).
    """
    mask = (index >= start) & (index <= end)
    dates_in_range = index[mask]

    # Group by ISO week and take the first trading day of each week
    ser = dates_in_range.to_series()
    iso = dates_in_range.isocalendar()
    weekly = ser.groupby([iso.year, iso.week]).first()

    # Convert to pd.Timestamp list (avoid numpy.datetime64 issues)
    result = sorted([pd.Timestamp(d) for d in weekly.values])


def compute_holding_returns(weights: pd.Series,
                            open_prices: pd.DataFrame,
                            adj_close: pd.DataFrame,
                            entry_date: pd.Timestamp,
                            exit_date: pd.Timestamp,
                            all_dates: pd.DatetimeIndex) -> Tuple[pd.Series, float]:
    """
    Compute daily returns for a holding period.

    Entry: buy at open of entry_date (Tuesday)
    Exit: sell at open of exit_date (next Tuesday)
    Intra-period: mark-to-market using adjusted close

    Returns:
    - daily_returns: Series indexed by date
    - total_return: cumulative return over the period
    """
    tickers = weights.index
    hold_dates = all_dates[(all_dates >= entry_date) & (all_dates < exit_date)]

    if len(hold_dates) == 0:
        return pd.Series(dtype=float), 0.0

    daily_rets = []
    daily_dates = []

    for i, hd in enumerate(hold_dates):
        if i == 0:
            # First day: entry at open, mark at close
            if hd in open_prices.index and hd in adj_close.index:
                entry_p = open_prices.loc[hd, tickers].reindex(tickers)
                close_p = adj_close.loc[hd, tickers].reindex(tickers)
                valid = entry_p.notna() & close_p.notna() & (entry_p > 0)
                if valid.any():
                    day_ret = ((close_p[valid] / entry_p[valid]) - 1)
                    port_ret = (weights[valid] * day_ret).sum() / weights.abs().sum() * (
                        config_gross_exposure(weights))
                    # Simpler: weighted return
                    port_ret = (weights.reindex(day_ret.index, fill_value=0) * day_ret).sum()
                    daily_rets.append(port_ret)
                    daily_dates.append(hd)
        else:
            # Subsequent days: close-to-close
            prev_date = hold_dates[i - 1]
            if prev_date in adj_close.index and hd in adj_close.index:
                prev_p = adj_close.loc[prev_date, tickers].reindex(tickers)
                curr_p = adj_close.loc[hd, tickers].reindex(tickers)
                valid = prev_p.notna() & curr_p.notna() & (prev_p > 0)
                if valid.any():
                    day_ret = (curr_p[valid] / prev_p[valid]) - 1
                    port_ret = (weights.reindex(day_ret.index, fill_value=0) * day_ret).sum()
                    daily_rets.append(port_ret)
                    daily_dates.append(hd)

    return pd.Series(daily_rets, index=daily_dates), np.nan


def config_gross_exposure(weights: pd.Series) -> float:
    """Compute gross exposure from weights."""
    return weights.abs().sum()


def run_backtest(signal: pd.DataFrame,
                 universe: pd.DataFrame,
                 data: Dict[str, pd.DataFrame],
                 config: dict,
                 cost_bps: Optional[float] = None,
                 label: str = "Strategy") -> Dict:
    """
    Weekly rebalance backtest.

    Timeline:
      Monday close (t): compute signal
      Tuesday open (t+1): execute trades using Open price
      Hold until next Tuesday open

    If cost_bps is provided, overrides config for stress testing.
    """
    if cost_bps is None:
        cost_bps = config['total_one_way_bps']

    adj_close = data['adj_close']
    open_prices = data['open']
    all_dates = adj_close.index

    # Find rebalance signal dates (Mondays)
    rebal_dates = find_rebalance_dates(all_dates, config['start_date'], config['end_date'])

    if len(rebal_dates) < 10:
        raise ValueError(f"Only {len(rebal_dates)} rebalance dates found.")

    # For each rebalance, the EXECUTION date is the next trading day (Tuesday)
    execution_dates = []
    for rd in rebal_dates:
        next_days = all_dates[all_dates > rd]
        if len(next_days) > 0:
            execution_dates.append(next_days[0])
        else:
            execution_dates.append(None)

    print(f"[BACKTEST:{label}] {len(rebal_dates)} rebalances, "
          f"{pd.Timestamp(rebal_dates[0]).date()} → {pd.Timestamp(rebal_dates[-1]).date()}, cost={cost_bps}bps")

    portfolio_returns = []
    portfolio_dates = []
    turnover_list = []
    prev_weights = pd.Series(dtype=float)

    for i in range(len(rebal_dates) - 1):
        signal_date = rebal_dates[i]      # Monday close
        entry_date = execution_dates[i]    # Tuesday open
        exit_date = execution_dates[i + 1] # Next Tuesday open

        if entry_date is None or exit_date is None:
            continue
        if signal_date not in signal.index:
            # Find nearest prior date in signal index
            prior = signal.index[signal.index <= signal_date]
            if len(prior) == 0:
                continue
            signal_date = prior[-1]

        # Build portfolio
        target = construct_portfolio(signal, universe, config, signal_date)
        if len(target) == 0:
            continue

        # Turnover
        combined = target.index.union(prev_weights.index)
        tw = target.reindex(combined, fill_value=0)
        pw = prev_weights.reindex(combined, fill_value=0)
        turnover = (tw - pw).abs().sum() / 2
        turnover_list.append({'date': signal_date, 'turnover': turnover})

        # Holding period returns (daily)
        hold_mask = (all_dates >= entry_date) & (all_dates < exit_date)
        hold_dates = all_dates[hold_mask]

        for j, hd in enumerate(hold_dates):
            if j == 0:
                # Entry day: open → close
                if hd in open_prices.index and hd in adj_close.index:
                    o = open_prices.loc[hd].reindex(target.index)
                    c = adj_close.loc[hd].reindex(target.index)
                    valid = o.notna() & c.notna() & (o > 0)
                    if valid.any():
                        dr = (c[valid] / o[valid]) - 1
                        pr = (target.reindex(dr.index, fill_value=0) * dr).sum()
                        portfolio_returns.append(pr)
                        portfolio_dates.append(hd)
            else:
                # Close-to-close
                prev_hd = hold_dates[j - 1]
                if prev_hd in adj_close.index and hd in adj_close.index:
                    p0 = adj_close.loc[prev_hd].reindex(target.index)
                    p1 = adj_close.loc[hd].reindex(target.index)
                    valid = p0.notna() & p1.notna() & (p0 > 0)
                    if valid.any():
                        dr = (p1[valid] / p0[valid]) - 1
                        pr = (target.reindex(dr.index, fill_value=0) * dr).sum()
                        portfolio_returns.append(pr)
                        portfolio_dates.append(hd)

        prev_weights = target.copy()

    # Build return series
    ret_gross = pd.Series(portfolio_returns, index=pd.DatetimeIndex(portfolio_dates),
                          name=label)

    # Apply costs
    to_df = pd.DataFrame(turnover_list)
    if len(to_df) > 0:
        to_df = to_df.set_index('date')
        avg_to = to_df['turnover'].mean()
        annual_to = avg_to * 52
    else:
        avg_to = 0
        annual_to = 0

    # Daily cost = (avg weekly turnover × round-trip cost) / 5 days
    daily_cost = avg_to * (cost_bps * 2) / 10000 / 5
    # Borrow cost on shorts
    daily_borrow = config['borrow_cost_annual_bps'] / 10000 / 252 * config['short_exposure']

    ret_net = ret_gross - daily_cost - daily_borrow

    return {
        'returns_gross': ret_gross,
        'returns_net': ret_net,
        'avg_weekly_turnover': avg_to,
        'annual_turnover': annual_to,
        'daily_cost_drag': daily_cost + daily_borrow,
        'cost_bps_used': cost_bps,
        'label': label,
    }


