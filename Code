# 6. REBALANCE DATE FINDER
# ============================================================================

def rebalance_dates(idx: pd.DatetimeIndex, start: str, end: str) -> List[pd.Timestamp]:
    """First trading day of each week within [start, end]."""
    mask = (idx >= start) & (idx <= end)
    ser = idx[mask].to_series()
    iso = idx[mask].isocalendar()
    weekly = ser.groupby([iso.year, iso.week]).first()
    return sorted([pd.Timestamp(d) for d in weekly.values])


