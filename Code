def download(tickers: List[str], cfg: dict) -> Dict[str, pd.DataFrame]:
    """Download OHLCV from yfinance. Cache to disk."""
    if os.path.exists(cfg['cache']):
        print(f"[DATA] Cache hit: {cfg['cache']}")
        with open(cfg['cache'], 'rb') as f:
            d = pickle.load(f)
        print(f"[DATA] {len(d['adj_close'].columns)} tickers × {len(d['adj_close'])} days")
        return d

    try:
        import yfinance as yf
    except ImportError:
        sys.exit("pip install yfinance")

    ws = (pd.Timestamp(cfg['start']) - pd.Timedelta(days=cfg['warmup_days'] * 2)).strftime('%Y-%m-%d')
    print(f"[DATA] Downloading {len(tickers)} tickers from {ws} to {cfg['end']}...")

    raw = yf.download(tickers, start=ws, end=cfg['end'],
                      auto_adjust=False, threads=True, progress=True)
    if raw.empty:
        sys.exit("[DATA] Empty download.")

    d = {}
    cols = {'adj_close': 'Adj Close', 'open': 'Open', 'close': 'Close', 'volume': 'Volume'}
    for k, c in cols.items():
        d[k] = raw[c].copy() if isinstance(raw.columns, pd.MultiIndex) else raw[[c]]

    # Keep tickers with enough data
    keep = d['adj_close'].notna().sum() >= cfg['min_history']
    keep = keep[keep].index.tolist()
    for k in d:
        d[k] = d[k][keep]
    print(f"[DATA] Kept {len(keep)} tickers")

    with open(cfg['cache'], 'wb') as f:
        pickle.dump(d, f)
    return d


