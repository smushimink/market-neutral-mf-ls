def apply_universe_filters(data: Dict[str, pd.DataFrame],
                           config: dict) -> pd.DataFrame:
    """
    Daily boolean mask: True = tradeable that day.
    Filters use ONLY past data (no look-ahead).
    """
    close = data['adj_close']
    volume = data['volume']

    price_ok = close >= config['min_price']
    dollar_vol = close * volume
    adv_20d = dollar_vol.rolling(20, min_periods=15).mean()
    adv_ok = adv_20d >= config['min_adv_dollars']
    history_ok = close.expanding().count() >= config['min_history_days']

    universe = price_ok & adv_ok & history_ok
    avg = universe.sum(axis=1).mean()
    print(f"[UNIVERSE] Avg tradeable size: {avg:.0f} stocks/day")
    print(f"[UNIVERSE] ⚠ SURVIVORSHIP BIAS: current constituents only. "
          f"Estimated bias: +1–3% ann return inflation (UPWARD).")
    return universe


