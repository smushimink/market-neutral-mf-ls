def placebo_test(features, universe, data, config, n=3) -> List[float]:
    """Randomize signals → should get Sharpe ≈ 0."""
    print(f"\n[ROBUSTNESS] Placebo test ({n} shuffles)...")
    results = []
    for i in range(n):
        composite = compute_composite(features, config)
        shuffled = composite.copy()
        for d in shuffled.index:
            v = shuffled.loc[d].dropna()
            if len(v) > 0:
                sv = v.values.copy()
                np.random.shuffle(sv)
                shuffled.loc[d, v.index] = sv
        bt = run_backtest(shuffled, universe, data, config, label=f"Placebo_{i+1}")
        m = metrics(bt['returns_net'])
        s = m.get('sharpe', 0)
        results.append(s)
        print(f"  Placebo {i+1}: Sharpe = {s:.3f}")
    return results


def shifted_signal_test(features, universe, data, config) -> float:
    """Use t+1 features → should show look-ahead inflation."""
    print("\n[ROBUSTNESS] Shifted signal test (t+1 features)...")
    shifted = {k: v.shift(-1) for k, v in features.items()}
    sig = compute_composite(shifted, config)
    bt = run_backtest(sig, universe, data, config, label="Shifted_t+1")
    m = metrics(bt['returns_net'])
    s = m.get('sharpe', 0)
    print(f"  Shifted Sharpe: {s:.3f} (should exceed real if features are predictive)")
    return s


def factor_ablation(features, universe, data, config) -> Dict[str, float]:
    """Each factor solo."""
    print("\n[ROBUSTNESS] Factor ablation...")
    results = {}
    for name in features:
        bt = run_backtest(features[name], universe, data, config, label=f"Solo_{name}")
        m = metrics(bt['returns_net'])
        s = m.get('sharpe', 0)
        results[name] = s
        print(f"  {name}: Sharpe = {s:.3f}")
    return results


def cost_stress_test(signal, universe, data, config) -> Dict[float, float]:
    """Net Sharpe under different cost assumptions."""
    print("\n[ROBUSTNESS] Cost stress test...")
    results = {}
    for bps in config['cost_stress_bps']:
        bt = run_backtest(signal, universe, data, config,
                          cost_bps=bps, label=f"Cost_{bps}bps")
        m = metrics(bt['returns_net'])
        s = m.get('sharpe', 0)
        results[bps] = s
        print(f"  {bps:.0f} bps: Net Sharpe = {s:.3f}")
    return results


