def train_ridge_walkforward(features: Dict[str, pd.DataFrame],
                            data: Dict[str, pd.DataFrame],
                            universe: pd.DataFrame,
                            config: dict) -> pd.DataFrame:
    """
    Walk-forward Ridge predicting 5-day forward returns.
    Target: (open_{t+6} / open_{t+1} - 1) to match Tuesday-to-Tuesday execution.
    """
    print("\n[MODEL] Walk-forward Ridge regression...")

    open_p = data['open']
    # 5-day forward return using open prices (Tue open → next Tue open)
    fwd_ret = open_p.pct_change(5).shift(-5)

    factor_names = list(features.keys())
    all_dates = data['adj_close'].index
    predictions = pd.DataFrame(np.nan, index=all_dates, columns=data['adj_close'].columns)

    bt_start = pd.Timestamp(config['start_date'])
    bt_end = pd.Timestamp(config['end_date'])
    train_w = config['train_window']
    step = config['step_size']

    steps = pd.date_range(bt_start, bt_end, freq=f'{step}B')

    n_trained = 0
    for test_start in steps:
        train_end = test_start - pd.Timedelta(days=1)
        train_dates = all_dates[all_dates <= train_end][-train_w:]
        test_dates = all_dates[(all_dates >= test_start) &
                               (all_dates < test_start + pd.Timedelta(days=step * 2))]

        if len(train_dates) < train_w // 2:
            continue

        # Build training data (sample every 5th day to reduce autocorrelation)
        X_parts = []
        for fn in factor_names:
            X_parts.append(features[fn].loc[train_dates[::5]].stack().rename(fn))
        if not X_parts:
            continue

        X = pd.concat(X_parts, axis=1).dropna()
        y = fwd_ret.loc[train_dates[::5]].stack().rename('target')
        common = X.index.intersection(y.dropna().index)

        if len(common) < 200:
            continue

        X_tr, y_tr = X.loc[common], y.loc[common]

        scaler = StandardScaler()
        X_sc = scaler.fit_transform(X_tr)
        model = Ridge(alpha=1.0)
        model.fit(X_sc, y_tr)

        # Predict test period
        for d in test_dates:
            if d not in all_dates:
                continue
            x_parts = []
            for fn in factor_names:
                if d in features[fn].index:
                    x_parts.append(features[fn].loc[d].rename(fn))
            if len(x_parts) == len(factor_names):
                x_test = pd.concat(x_parts, axis=1).dropna()
                if len(x_test) > 0:
                    preds = model.predict(scaler.transform(x_test))
                    predictions.loc[d, x_test.index] = preds

        n_trained += 1

    predictions = zscore_xs(predictions)
    valid = predictions.notna().sum(axis=1)
    valid_days = valid[valid > 0]
    print(f"[MODEL] {n_trained} train steps, predictions on {len(valid_days)} days, "
          f"avg {valid_days.mean():.0f} stocks/day")
    return predictions


